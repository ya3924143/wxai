# wxai 环境变量配置

# 必填：API Key（用于 Web UI 认证和外部 API 调用）
WXAI_API_KEY=your-secret-key-here

# 可选：Web UI 登录密码（默认同 API Key）
WXAI_PASSWORD=

# 可选：HTTP 服务端口（默认 3800）
WXAI_PORT=3800

# 可选：HTTP 服务地址（默认 127.0.0.1）
WXAI_HOST=127.0.0.1

# ── AI Provider 配置 ──

# AI Provider 类型：claude-cli | anthropic-api | openai-compat
WXAI_AI_PROVIDER=claude-cli

# Claude CLI provider（默认，需本机安装 Claude Code CLI）
# 无需额外配置，使用本机已登录的 Claude 账号

# Anthropic API provider（需 API Key）
# ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI 兼容 provider（GPT、DeepSeek、本地模型等）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
